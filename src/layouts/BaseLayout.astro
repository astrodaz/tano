---

import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Exploits and adventures in astronomy from rural Bedfordshire" } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | The Alan Norman Observatory</title>
    <meta name="description" content={description} />
    <script is:inline>
      document.documentElement.classList.add("dark");
    </script>
    <style>
      .dot-hexagon-dark {
        background-image: radial-gradient(
            circle,
            #ffffff20 1px,
            transparent 1px
          ),
          radial-gradient(circle, #ffffff20 1px, transparent 1px);
        background-size: 24px 41.57px;
        background-position:
          0 0,
          12px 20.78px;
      }
    </style>
  </head>
  <body
    class="min-h-screen flex flex-col bg-space-950 transition-colors duration-300"
  >
    <div class="relative flex-grow flex flex-col">
      <div class="absolute inset-0 overflow-hidden pointer-events-none">
        <div class="absolute inset-0 dot-hexagon-dark"></div>
        <div
          class="absolute inset-0 bg-[radial-gradient(ellipse_80%_80%_at_50%_50%,transparent_0%,rgba(8,8,16,0.5)_60%,rgba(8,8,16,0.9)_85%,rgb(8,8,16)_100%)]"
        >
        </div>
        <div
          class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 h-[1200px] w-[1200px] rounded-full bg-nebula-700 opacity-5 blur-[120px]"
          style="max-height: 100vh; max-width: 100vw;"
        >
        </div>
      </div>

      <Navigation />
      
      <main class="relative z-20 flex-grow">
        <slot />
      </main>

      <Footer />
    </div>
  </body>
</html>