---
import { siteConfig } from "../config/content";
---

<!-- Footer Component -->
<footer class="relative border-t border-space-700 mt-12">
  <div class="container mx-auto px-4 max-w-7xl py-8">

    <!-- Clear Outside widget -->
    <div class="flex justify-center mb-6">
      <a href="https://clearoutside.com/forecast/52.14/-0.46" target="_blank">
        <img
          src="https://clearoutside.com/forecast_image_medium/52.14/-0.46/forecast.png"
          alt="Clear Outside Weather Forecast"
          class="rounded-lg opacity-90 hover:opacity-100 transition-opacity"
        />
      </a>
    </div>

    <!-- Bottom row - copyright and credits -->
    <div class="flex justify-center">
      <p class="text-sm text-starlight-400 text-center">
        © {new Date().getFullYear()} Darren Jehan. All rights reserved. · Built with 
        <a href="https://astro.build" target="_blank" class="text-nebula-500 hover:text-nebula-300 transition-colors">Astro</a> 
        and 
        <a href="https://tailwindcss.com" target="_blank" class="text-nebula-500 hover:text-nebula-300 transition-colors">Tailwind CSS</a>
      </p>
    </div>

  </div>
</footer>