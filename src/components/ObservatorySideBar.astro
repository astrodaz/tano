---
import { imagerLinks } from "../config/content.ts";
---

<div class="rounded-xl border border-space-700 bg-space-900 p-6 mb-6">
  <h3 class="text-lg font-bold text-starlight-200 mb-4">The Observatory</h3>
  <ul class="space-y-2">
    <li>
      <a href="/about/" class="text-starlight-400 hover:text-nebula-500 transition-colors">
        About
      </a>
    </li>
    <li>
      <a href="/observatory/construction" class="text-starlight-400 hover:text-nebula-500 transition-colors">
        Construction Gallery
      </a>
    </li>
    <li>
      <a href="/observatory/equipment/" class="text-starlight-400 hover:text-nebula-500 transition-colors">
        Equipment
      </a>
    </li>
  </ul>
</div>

<div class="rounded-xl border border-space-700 bg-space-900 p-6 mb-6">
  <h3 class="text-lg font-bold text-starlight-200 mb-4">{imagerLinks.title}</h3>
  <ul class="space-y-2">
    {
      imagerLinks.imagers.map((item) => (
        <li>
          <a
            href={item.link}
            target="_blank"
            class="text-starlight-400 hover:text-nebula-500 transition-colors"
          >
            {item.name}
          </a>
        </li>
      ))
    }
  </ul>
</div>

<div class="rounded-xl border border-space-700 bg-space-900 p-6">
  <h3 class="text-lg font-bold text-starlight-200 mb-4">Local Seeing</h3>
  <a href="http://clearoutside.com/forecast/52.14/-0.47" target="_blank">
    <img
      src="http://clearoutside.com/forecast_image_small/52.14/-0.47/forecast.png"
      alt="Clear Outside Forecast"
      class="w-full rounded-lg"
    />
  </a>
</div>