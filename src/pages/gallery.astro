---
const { filters } = post.data.acquisition;

// Calculate total time automatically!
const totalSeconds = filters.reduce((acc, f) => acc + (f.count * f.duration), 0);
const totalHours = (totalSeconds / 3600).toFixed(1);

// Helper to get CSS colors based on filter type
const getFilterColor = (type) => {
  const colors = {
    Ha: 'text-red-500', 
    OIII: 'text-aurora-400', 
    SII: 'text-red-800', 
    L: 'text-starlight-100',
    R: 'text-red-600',
    G: 'text-green-500',
    B: 'text-blue-500'
  };
  return colors[type] || 'text-starlight-400';
};
---

<div class="grid grid-cols-2 gap-4 bg-space-900 p-6 rounded-xl border border-space-700">
  <div>
    <h4 class="text-starlight-500 text-xs uppercase mb-2">Integration</h4>
    <p class="text-2xl font-bold text-starlight-100">{totalHours} Hours</p>
  </div>
  
  <ul class="space-y-1">
    {filters.map(f => (
      <li class="flex justify-between text-sm border-b border-space-800 pb-1">
        <span class={`font-bold ${getFilterColor(f.type)}`}>{f.type}</span>
        <span class="text-starlight-300">{f.count} x {f.duration}s</span>
      </li>
    ))}
  </ul>
</div>