---
import Layout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

// 1. Fetch all gallery entries and sort by newest date
const allImages = await getCollection('gallery');
const sortedImages = allImages.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="Astrophotography Gallery">
  <main class="max-w-7xl mx-auto px-4 py-12">
    <header class="mb-12">
      <h1 class="text-4xl font-black text-starlight-100 mb-2">Deep Sky Gallery</h1>
      <p class="text-starlight-400">Captures from the observatory logbook.</p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {sortedImages.map((item) => (
        <a href={`/gallery/${item.id}`} class="group bg-space-900 border border-space-800 rounded-2xl overflow-hidden hover:border-nebula-500 transition-all duration-300 shadow-xl">
          
          <div class="aspect-video overflow-hidden relative">
            <Image 
              src={item.data.mainPhoto} 
              alt={item.data.title}
              width={800}
              height={450}
              class="object-cover w-full h-full transition-transform duration-500 group-hover:scale-110"
            />
            <div class="absolute top-3 left-3 px-2 py-1 bg-space-950/80 backdrop-blur-md border border-space-700 rounded text-[10px] font-bold uppercase tracking-widest text-aurora-400">
              {item.data.target.type}
            </div>
          </div>

          <div class="p-5">
            <h2 class="text-xl font-bold text-starlight-100 mb-1 group-hover:text-nebula-400 transition-colors">
              {item.data.title}
            </h2>
            
            <div class="flex items-center justify-between mt-4">
              <span class="text-xs text-starlight-500 font-mono">
                {item.data.gear.scope}
              </span>
              <span class="text-[10px] font-bold px-2 py-0.5 rounded bg-space-800 text-starlight-300 border border-space-700">
                {item.data.date.toLocaleDateString('en-GB', { year: 'numeric', month: 'short' })}
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </main>
</Layout>