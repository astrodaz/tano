---
import BlogLayout from "../../layouts/BlogLayout.astro";
import { getPostBySlug, getAllPostSlugs } from "../../utils/getPosts";

export async function getStaticPaths() {
  const slugs = getAllPostSlugs();
  return slugs.map((slug) => ({
    params: { slug },
  }));
}

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect("/posts/");
}

const post = getPostBySlug(slug);

if (!post) {
  return Astro.redirect("/posts/");
}

const { frontmatter, Content } = post;

if (!Content) {
  console.error(`Content component not found for slug: ${slug}`);
  return Astro.redirect("/posts/");
}
---

<BlogLayout 
  title={frontmatter.title || ""}
  description={frontmatter.description}
  date={frontmatter.date ? new Date(frontmatter.date).toLocaleDateString("en-GB", {
    year: "numeric",
    month: "long",
    day: "numeric",
  }) : ""}
  readTime={frontmatter.readTime}
>

  <!-- Blog sidebar -->
  <div slot="sidebar">
    <div class="rounded-xl border border-space-700 bg-space-900 p-6 mb-6">
      <h3 class="text-lg font-bold text-starlight-200 mb-4">Recent Posts</h3>
      <ul class="space-y-2">
        <li>
          <a href="/posts/" class="text-starlight-400 hover:text-nebula-500 transition-colors">
            All Posts
          </a>
        </li>
      </ul>
    </div>

    <div class="rounded-xl border border-space-700 bg-space-900 p-6 mb-6">
      <h3 class="text-lg font-bold text-starlight-200 mb-4">Fellow Imagers</h3>
      <ul class="space-y-2">
        <li>
          <a href="http://nightskyimages.co.uk/" target="_blank" class="text-starlight-400 hover:text-nebula-500 transition-colors">
            Steve Richards
          </a>
        </li>
        <li>
          <a href="http://www.digitalsky.org.uk/" target="_blank" class="text-starlight-400 hover:text-nebula-500 transition-colors">
            Pete Lawrence
          </a>
        </li>
        <li>
          <a href="http://www.astrobin.com/users/timjardine/" target="_blank" class="text-starlight-400 hover:text-nebula-500 transition-colors">
            Tim Jardine
          </a>
        </li>
        <li>
          <a href="http://www.eagleseye.me.uk/Sky/Wordpress/" target="_blank" class="text-starlight-400 hover:text-nebula-500 transition-colors">
            Dave Eagle
          </a>
        </li>
      </ul>
    </div>

    <div class="rounded-xl border border-space-700 bg-space-900 p-6 mb-6">
      <h3 class="text-lg font-bold text-starlight-200 mb-4">Astronomy Links</h3>
      <ul class="space-y-2">
        <li>
          <a href="http://stargazerslounge.com" target="_blank" class="text-starlight-400 hover:text-nebula-500 transition-colors">
            Stargazers Lounge
          </a>
        </li>
        <li>
          <a href="http://bedsastro.org.uk" target="_blank" class="text-starlight-400 hover:text-nebula-500 transition-colors">
            Bedford AS
          </a>
        </li>
        <li>
          <a href="https://www.ldas.org.uk" target="_blank" class="text-starlight-400 hover:text-nebula-500 transition-colors">
            Letchworth & District AS
          </a>
        </li>
        <li>
          <a href="http://britastro.org" target="_blank" class="text-starlight-400 hover:text-nebula-500 transition-colors">
            The BAA
          </a>
        </li>
      </ul>
    </div>

    <div class="rounded-xl border border-space-700 bg-space-900 p-6">
      <h3 class="text-lg font-bold text-starlight-200 mb-4">Local Seeing</h3>
      <a href="http://clearoutside.com/forecast/52.14/-0.47" target="_blank">
        <img
          src="http://clearoutside.com/forecast_image_small/52.14/-0.47/forecast.png"
          alt="Clear Outside Forecast"
          class="w-full rounded-lg"
        />
      </a>
    </div>
  </div>

  <!-- Post content -->
  <div class="prose prose-invert prose-lg max-w-none
    prose-headings:text-starlight-100
    prose-p:text-starlight-400
    prose-a:text-nebula-500
    prose-a:no-underline
    hover:prose-a:text-nebula-300
    prose-strong:text-starlight-200
    prose-code:text-aurora-400
    prose-blockquote:border-nebula-500
    prose-blockquote:text-starlight-400
    prose-li:text-starlight-400
    prose-hr:border-space-700">
    <Content />
  </div>

</BlogLayout>