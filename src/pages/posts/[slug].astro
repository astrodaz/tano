---
import BlogLayout from "../../layouts/BlogLayout.astro";
import { getPostBySlug, getAllPostSlugs } from "../../utils/getPosts";
import BlogSideBar from "../..//components/BlogSideBar.astro";

export async function getStaticPaths() {
  const slugs = getAllPostSlugs();
  return slugs.map((slug) => ({
    params: { slug },
  }));
}

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect("/posts/");
}

const post = getPostBySlug(slug);

if (!post) {
  return Astro.redirect("/posts/");
}

const { frontmatter, Content } = post;

if (!Content) {
  console.error(`Content component not found for slug: ${slug}`);
  return Astro.redirect("/posts/");
}
---

<BlogLayout 
  title={frontmatter.title || ""}
  description={frontmatter.description}
  date={frontmatter.date ? new Date(frontmatter.date).toLocaleDateString("en-GB", {
    year: "numeric",
    month: "long",
    day: "numeric",
  }) : ""}
  readTime={frontmatter.readTime}
  tags={frontmatter.tags || []}
>

  <!-- Blog sidebar -->
  <div slot="sidebar">
    <BlogSideBar />
  </div>

  <!-- Post content -->
  <div class="prose prose-invert prose-lg max-w-none
    prose-headings:text-starlight-100
    prose-p:text-starlight-400
    prose-a:text-nebula-500
    prose-a:no-underline
    hover:prose-a:text-nebula-300
    prose-strong:text-starlight-200
    prose-code:text-aurora-400
    prose-blockquote:border-nebula-500
    prose-blockquote:text-starlight-400
    prose-li:text-starlight-400
    prose-hr:border-space-700">
    <Content />
  </div>

</BlogLayout>