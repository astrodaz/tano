---
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
import { siteConfig, homeContent } from "../config/content.ts";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{siteConfig.title}</title>
    <meta name="description" content={siteConfig.description} />

    <script is:inline>
      document.documentElement.classList.add("dark");
    </script>    

    <style>
      body {
        margin: 0;
        font-family:
          system-ui,
          -apple-system,
          sans-serif;
      }

      @keyframes float {
        0% {
          transform: scale(1.05);
        }
        50% {
          transform: scale(1.1);
        }
        100% {
          transform: scale(1.05);
        }
      }

      .dot-hexagon-dark {
        background-image: radial-gradient(
            circle,
            #ffffff20 1px,
            transparent 1px
          ),
          radial-gradient(circle, #ffffff20 1px, transparent 1px);
        background-size: 24px 41.57px;
        background-position:
          0 0,
          12px 20.78px;
      }
    </style>
  </head>
  <body
    class="min-h-screen flex flex-col bg-space-950 transition-colors duration-300"
  >
    <div class="relative flex-grow flex flex-col">
      <div class="absolute inset-0 overflow-hidden pointer-events-none">
        <div class="absolute inset-0 dot-hexagon-dark"></div>
        <div
          class="absolute inset-0 bg-[radial-gradient(ellipse_80%_80%_at_50%_50%,transparent_0%,rgba(8,8,16,0.5)_60%,rgba(8,8,16,0.9)_85%,rgb(8,8,16)_100%)]"
        >
        </div>
        <div
          class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 h-[1200px] w-[1200px] rounded-full bg-nebula-700 opacity-5 blur-[120px]"
          style="max-height: 100vh; max-width: 100vw;"
        >
        </div>
      </div>

      <Navigation />
      <div class="relative flex flex-col flex-1 pt-4 min-h-0">
        <main class="flex-grow flex flex-col min-h-0">
          <div class="flex-1 flex items-center justify-center min-h-0">
            <div
              class="flex flex-row items-center justify-between w-full max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 gap-12"
            >
              <div class="w-[45%] text-left">
                <h1
                  class="text-4xl font-bold tracking-tight text-starlight-100 sm:text-5xl"
                >
                  {homeContent.title}
                </h1>
                <p class="mt-4 text-lg leading-8 text-starlight-400">
                  My name is Darren Jehan, an amateur astronomer based in Bedfordshire. The site contains my astro-images, observing/imaging reports and various articles of astronomy related topics.
                </p>
                <p class="mt-3 text-lg leading-8 text-starlight-400">
                  I am an active member of <a href="https://bedsastro.org.uk" target="_blank" class="text-nebula-500 hover:text-nebula-300 transition-colors">BAS</a> - Bedford Astronomical Society and <a href="https://ldas.org.uk" target="_blank" class="text-nebula-500 hover:text-nebula-300 transition-colors">LDAS</a> - Letchworth and District Astronomical Society and enjoy bringing astronomy to the public through outreach events and public observing sessions.
                </p>
                <p class="mt-3 text-lg leading-8 text-starlight-400">
                  I am also one of the team of administrators on <a href="https://stargazerslounge.com" target="_blank" class="text-nebula-500 hover:text-nebula-300 transition-colors">Stargazers Lounge</a> - one of the world's largest amateur astronomy forums. Be sure to drop by the Lounge - you'll find useful information, as well as discussions on all astro-related subjects!
                </p>

                <div class="flex flex-row gap-4 mt-6">
                  <a
                    class="group inline-flex items-center gap-2 px-5 py-2.5 text-sm font-semibold text-space-950 bg-nebula-500 rounded-lg hover:bg-nebula-400 transition-all duration-300 hover:scale-105 cursor-pointer"
                    href={homeContent.buttons.about.href}
                    >{homeContent.buttons.about.text}<svg
                      class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                      ><path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2.5"
                        d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg
                    ></a
                  >
                  <a
                    class="group inline-flex items-center gap-2 px-5 py-2.5 text-sm font-semibold text-starlight-200 border border-aurora-500 rounded-lg hover:bg-aurora-500 hover:text-space-950 transition-all duration-300 hover:scale-105 cursor-pointer"
                    href={homeContent.buttons.posts.href}
                    >{homeContent.buttons.posts.text}<svg
                      class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                      ><path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2.5"
                        d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg
                    ></a
                  >
                </div>
              </div>
              <div
                class="relative w-[45%] flex items-center justify-center bg-transparent overflow-hidden z-20"
              >
                <div
                  class="relative overflow-hidden"
                  style="width: min(700px, 45vw); height: min(700px, 70vh); max-width: 100%; max-height: 70vh;"
                >
                  <img
                    src={homeContent.images.dark}
                    alt="Astrophotography"
                    class="w-full h-full object-contain animate-[float_15s_ease-in-out_infinite] hover:scale-110 transition-transform duration-300 opacity-90 rounded-xl"
                    style="max-width: 100%; max-height: 100%;"
                  />
                </div>
              </div>
            </div>
          </div>         
        </main>

        <Footer />
      </div>
    </div>
  </body>
</html>