---
import PageLayout from "../../layouts/PageLayout.astro";
import { Automation2022Content } from "../../config/content.ts";
---

<PageLayout title={Automation2022Content.meta.title} description={Automation2022Content.meta.description}>

  <!-- Sidebar -->
  <div slot="sidebar">
    <div class="rounded-xl border border-space-700 bg-space-900 p-6 mb-6">
      <h3 class="text-lg font-bold text-starlight-200 mb-4">The Observatory</h3>
      <ul class="space-y-2">
        <li>
          <a href="/about/" class="text-starlight-400 hover:text-nebula-500 transition-colors">
            About
          </a>
        </li>
        <li>
          <a href="/about/#gallery" class="text-starlight-400 hover:text-nebula-500 transition-colors">
            Construction Gallery
          </a>
        </li>
        <li>
          <a href="/observatory/automation2022/" class="text-starlight-400 hover:text-nebula-500 transition-colors">
            2022 Automation Project
          </a>
        </li>
        <li>
          <a href="/observatory/equipment/" class="text-starlight-400 hover:text-nebula-500 transition-colors">
            Equipment
          </a>
        </li>
        <li>
          <a href="/observatory/original/" class="text-starlight-400 hover:text-nebula-500 transition-colors">
            Original Observatory
          </a>
        </li>
      </ul>
    </div>

    <div class="rounded-xl border border-space-700 bg-space-900 p-6 mb-6">
      <h3 class="text-lg font-bold text-starlight-200 mb-4">Fellow Imagers</h3>
      <ul class="space-y-2">
        <li>
          <a href="http://nightskyimages.co.uk/" target="_blank" class="text-starlight-400 hover:text-nebula-500 transition-colors">
            Steve Richards
          </a>
        </li>
        <li>
          <a href="http://www.digitalsky.org.uk/" target="_blank" class="text-starlight-400 hover:text-nebula-500 transition-colors">
            Pete Lawrence
          </a>
        </li>
        <li>
          <a href="http://www.astrobin.com/users/timjardine/" target="_blank" class="text-starlight-400 hover:text-nebula-500 transition-colors">
            Tim Jardine
          </a>
        </li>
        <li>
          <a href="http://www.eagleseye.me.uk/Sky/Wordpress/" target="_blank" class="text-starlight-400 hover:text-nebula-500 transition-colors">
            Dave Eagle
          </a>
        </li>
      </ul>
    </div>

    <div class="rounded-xl border border-space-700 bg-space-900 p-6">
      <h3 class="text-lg font-bold text-starlight-200 mb-4">Local Seeing</h3>
      <a href="http://clearoutside.com/forecast/52.14/-0.47" target="_blank">
        <img
          src="http://clearoutside.com/forecast_image_small/52.14/-0.47/forecast.png"
          alt="Clear Outside Forecast"
          class="w-full rounded-lg"
        />
      </a>
    </div>
  </div>

  <!-- Main content -->
  <div class="relative z-20 w-full">
    <h2 class="text-5xl font-bold tracking-tight text-starlight-100 sm:text-6xl">
      {Automation2022Content.title}
    </h2>
    <div class="flex flex-col md:flex-row gap-8 mt-6">
      <div class="w-full md:w-1/2 flex flex-col">
        <p class="text-lg leading-8 text-starlight-400">
          {Automation2022Content.description}
        </p>
        <div class="mt-6 flex flex-wrap gap-2">
          {
            Automation2022Content.skills.map((skill) => (
              <span class="px-3 py-1 text-sm bg-space-800 text-aurora-500 border border-space-700 rounded-full">
                {skill}
              </span>
            ))
          }
        </div>
      </div>
      <div class="w-full md:w-1/2 flex justify-end">
        <div class="relative w-[360px] h-[360px]">
          <img
            src={Automation2022Content.image.src}
            alt={Automation2022Content.image.alt}
            class="object-cover rounded-xl w-full h-full"
          />
        </div>
      </div>
    </div>
  </div>

</PageLayout>