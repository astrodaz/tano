---
import PageLayout from "../../layouts/PageLayout.astro";
import { equipmentContent } from "../../config/content.ts";
import ObservatorySideBar from "../../components/ObservatorySideBar.astro";
---

<PageLayout title={equipmentContent.meta.title} description={equipmentContent.meta.description}>

  <!-- Sidebar -->
  <div slot="sidebar">
    <ObservatorySideBar />
  </div>


  <!-- Main content -->
  <div class="relative z-20 w-full">
    <h2 class="text-5xl font-bold tracking-tight text-starlight-100 sm:text-6xl">
      {equipmentContent.title}
    </h2>
    <div class="flex flex-col md:flex-row gap-8 mt-6">
      <div class="w-full md:w-1/2 flex flex-col">
        <p class="text-lg leading-8 text-starlight-400">
          The current main equipment I use...
        </p>
      </div>
    </div>
  </div>

  <div class="flex flex-col md:flex-row mt-20 gap-8">
    <div class="flex-1">
      <h2 class="mb-2 text-2xl font-bold text-starlight-200">
        {equipmentContent.experience.title}
      </h2>
      <div class="py-10">
        {
          equipmentContent.experience.items.map((item) => (
            <div class="pb-10 border-l border-space-700 last:border-l-0">
              <div class="relative flex flex-col justify-start pl-12">
                <div class="absolute top-0 left-0 z-40 flex items-center justify-center -translate-x-1/2 bg-space-950 border rounded-full w-14 h-14 border-space-700">
                  <svg
                    class="w-8 h-8 text-nebula-500"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="1.5"
                      d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"
                    />
                  </svg>
                </div>
                <p class="text-xs uppercase text-starlight-400 tracking-widest">
                  {item.type}
                </p>
                <h3 class="my-1 text-lg font-bold text-starlight-100">
                  {item.make}
                </h3>
                <p class="my-1 text-lg font-bold text-starlight-100">
                  {item.aperture}, {item.fratio}
                </p>
                <p class="text-sm font-light text-starlight-400">
                  {item.description}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <div class="flex-1">
      <h2 class="mb-2 text-2xl font-bold text-starlight-200">
        {equipmentContent.software.title}
      </h2>
      <div class="py-10">
      {
        equipmentContent.software.items.map((item) => (
        <div class="pb-10 border-l border-space-700 last:border-l-0">
          <div class="relative flex flex-col justify-start pl-12">
            <div class="absolute top-0 left-0 z-40 flex items-center justify-center -translate-x-1/2 bg-space-950 border rounded-full w-14 h-14 border-space-700">
              <svg
                class="w-8 h-8 text-nebula-500"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"
                />
              </svg>
            </div>
            <p class="text-xs uppercase text-starlight-400 tracking-widest">
              {item.description}
            </p>
            <h3 class="my-1 text-lg font-bold text-starlight-100">
              {item.name}
            </h3>
            <p class="text-lg font-light text-starlight-400">
              {item.author}
            </p>
            <p class="text-lg font-light text-starlight-400">
              <a
                href={item.link}
                class="text-nebula-500 hover:text-nebula-300 transition-colors italic"
                target="_blank"
                rel="noopener noreferrer"                
              >
                Visit vendor...
              </a>
            </p>
          </div>
            
        </div>
        ))
      }

      <h2 class="mb-2 text-2xl font-bold text-starlight-200">
        {equipmentContent.camera.title}
      </h2>
      {
        equipmentContent.camera.items.map((item) => (
        <div class="pb-10 border-l border-space-700 last:border-l-0">
          <div class="relative flex flex-col justify-start pl-12">
            <div class="absolute top-0 left-0 z-40 flex items-center justify-center -translate-x-1/2 bg-space-950 border rounded-full w-14 h-14 border-space-700">
              <svg
                class="w-8 h-8 text-nebula-500"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"
                />
              </svg>
            </div>
            <p class="text-xs uppercase text-starlight-400 tracking-widest">
              {item.description}
            </p>
            <h3 class="my-1 text-lg font-bold text-starlight-100 transition-all duration-300 hover:scale-105 hover:text-aurora-400 cursor-default inline-block origin-left">
              <a href={item.image} class="glightbox">{item.model}</a>
            </h3>
            <p class="text-sm font-light text-starlight-400">
              {item.make}
            </p>
            <p class="text-lg font-light text-starlight-400">
              <a 
                href={item.link}
                target="_blank"
                rel="noopener noreferrer"
                class="text-nebula-500 hover:text-nebula-300 transition-colors italic"
              >
                View specs...
              </a>
            </p>            
          </div>
        </div>
        ))
      }
      </div>
    </div>
  </div>

  <script>
    import GLightbox from 'glightbox';
    import 'glightbox/dist/css/glightbox.css';
    
    const lightbox = GLightbox({
      touchNavigation: true,
      loop: true,
      autoplayVideos: false,
    });
  </script>

</PageLayout>