---
import PageLayout from "../layouts/PageLayout.astro";
import { projectsContent } from "../config/projects.ts";
import { solarSystemContent } from "../config/projects.ts";
---

<PageLayout title={projectsContent.meta.title} description={projectsContent.meta.description}>

  <!-- Sidebar -->
  <div slot="sidebar">
    <div class="rounded-xl border border-space-700 bg-space-900 p-6 mb-6">
      <h3 class="text-lg font-bold text-starlight-200 mb-4">Images</h3>
      <ul class="space-y-2">
        <li>
          <a href="/projects/" class="text-starlight-400 hover:text-nebula-500 transition-colors">
            All Images
          </a>
        </li>
      </ul>
    </div>

    <div class="rounded-xl border border-space-700 bg-space-900 p-6 mb-6">
      <h3 class="text-lg font-bold text-starlight-200 mb-4">Fellow Imagers</h3>
      <ul class="space-y-2">
        <li>
          <a href="http://nightskyimages.co.uk/" target="_blank" class="text-starlight-400 hover:text-nebula-500 transition-colors">
            Steve Richards
          </a>
        </li>
        <li>
          <a href="http://www.digitalsky.org.uk/" target="_blank" class="text-starlight-400 hover:text-nebula-500 transition-colors">
            Pete Lawrence
          </a>
        </li>
        <li>
          <a href="http://www.astrobin.com/users/timjardine/" target="_blank" class="text-starlight-400 hover:text-nebula-500 transition-colors">
            Tim Jardine
          </a>
        </li>
        <li>
          <a href="http://www.eagleseye.me.uk/Sky/Wordpress/" target="_blank" class="text-starlight-400 hover:text-nebula-500 transition-colors">
            Dave Eagle
          </a>
        </li>
      </ul>
    </div>

    <div class="rounded-xl border border-space-700 bg-space-900 p-6">
      <h3 class="text-lg font-bold text-starlight-200 mb-4">Resources</h3>
      <ul class="space-y-2">
        <li>
          <a href="http://firstlightoptics.com" target="_blank" class="text-starlight-400 hover:text-nebula-500 transition-colors">
            First Light Optics
          </a>
        </li>
        <li>
          <a href="http://adamblockstudios.com" target="_blank" class="text-starlight-400 hover:text-nebula-500 transition-colors">
            Adam Block Studios
          </a>
        </li>
        <li>
          <a href="http://pixinsight.com" target="_blank" class="text-starlight-400 hover:text-nebula-500 transition-colors">
            PixInsight
          </a>
        </li>
        <li>
          <a href="http://britastro.org" target="_blank" class="text-starlight-400 hover:text-nebula-500 transition-colors">
            The BAA
          </a>
        </li>
      </ul>
    </div>
  </div>

  <!-- Main content -->
  <div class="relative z-20 w-full">
    <h2 class="text-5xl font-bold tracking-tight text-starlight-100 sm:text-6xl">
      {projectsContent.title}
    </h2>
    <p class="mt-4 text-lg leading-8 text-starlight-400">
      {projectsContent.description}
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-1 gap-6 mt-10">
      {
        projectsContent.sections.map((section) => (
          <section>
            <h3 class="mb-8 text-3xl font-bold text-starlight-200">
              {section.header}
            </h3>
            <div class="grid grid-cols-4">
              {section.items.map((item) => (
                <a
                  href={item.image}
                  class="mb-4 glightbox group relative flex flex-col rounded-2xl border border-space-700 bg-space-900 overflow-hidden hover:border-nebula-500 transition-all duration-300"
                  data-glightbox={`title: ${item.title}`}>
                  <div class="overflow-hidden">
                    <img
                      src={item.image}
                      alt={item.title}
                      class="w-full aspect-[16/9] object-cover group-hover:scale-105 transition-transform duration-500"
                    />
                  </div>
                  <div class="p-4">
                    <h3 class="text-lg font-semibold text-starlight-100 group-hover:text-nebula-500 transition-colors">
                      {item.title}
                    </h3>
                    <p class="mt-1 text-sm text-starlight-400">
                      {item.description}
                    </p>
                  </div>
                </a>
              ))}
            </div>
          </section>
        ))
      }
          
  </div>

  <script>
    import GLightbox from 'glightbox';
    import 'glightbox/dist/css/glightbox.css';
    
    const lightbox = GLightbox({
      touchNavigation: true,
      loop: true,
      autoplayVideos: false,
    });
  </script>

</PageLayout>